# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

N8N_VERSION=stable

# Postgres superuser (used only for init; n8n never connects with this account)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeMe
POSTGRES_DB=n8n

# Separate, least-privilege account n8n actually connects with.
# Must be DIFFERENT from POSTGRES_USER above.
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=changeMeToo

# Shared secret between n8n and the task runner. Generate with: openssl rand -hex 32
RUNNERS_AUTH_TOKEN=changeRunnerAuthToken

# Encrypts credentials stored by n8n. Generate once with: openssl rand -hex 32
# Losing this key after workflows have saved credentials makes them unrecoverable.
N8N_ENCRYPTION_KEY=changeEncryptionKey

# Public-facing hostname/protocol used to build webhook URLs.
# Dev: overridden to localhost/http in docker-compose.override.yml
# Prod: set to your real domain, served via Caddy in docker-compose.prod.yml
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/

# NocoDB — separate database + user on the same Postgres instance.
NOCODB_VERSION=latest
NC_DB_USER=nocodb
NC_DB_PASSWORD=changeNocodbPassword
NC_DB=nocodb
NC_ALLOW_LOCAL_EXTERNAL_DBS=true

# Prod: subdomain served by Caddy, e.g. nocodb.example.com
NC_HOST=nocodb.example.com

# Separate app database + user on the same Postgres instance.
# Connect to it from NocoDB as an external "Base" (host: postgres, port: 5432).
APP_DB_USER=appdata
APP_DB_PASSWORD=changeAppDbPassword
APP_DB=appdata
