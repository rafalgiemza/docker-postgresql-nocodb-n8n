# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

N8N_VERSION=stable

# Postgres superuser (used only for init; n8n never connects with this account)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeMe
POSTGRES_DB=n8n

# Separate, least-privilege account n8n actually connects with.
# Must be DIFFERENT from POSTGRES_USER above.
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=changeMeToo

# Shared secret between n8n and the task runner. Generate with: openssl rand -hex 32
RUNNERS_AUTH_TOKEN=changeRunnerAuthToken

# Encrypts credentials stored by n8n. Generate once with: openssl rand -hex 32
# Losing this key after workflows have saved credentials makes them unrecoverable.
N8N_ENCRYPTION_KEY=changeEncryptionKey

# Public-facing hostname/protocol used to build webhook URLs.
# Dev: overridden to localhost/http in docker-compose.override.yml
# Prod: set to your real domain, served via Caddy in docker-compose.prod.yml.
# Caddy does NOT terminate TLS itself (see CADDY_HTTP_PORT below) — protocol
# stays https here because that's what's public-facing, e.g. via mikr.us.
N8N_HOST=n8n-coaction.byst.re
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n-coaction.byst.re/

# Prod: internal HTTP port Caddy listens on, routing N8N_HOST/NC_HOST by Host
# header. No TLS here — meant for hosting behind mikr.us's `domena` tool,
# which terminates SSL at its own edge and forwards plain HTTP to this port.
# Register both hostnames with mikr.us pointing at this same port:
#   domena n8n-coaction.byst.re 8000
#   domena back-office-coaction.byst.re 8000
CADDY_HTTP_PORT=8000

# NocoDB — separate database + user on the same Postgres instance.
NOCODB_VERSION=latest
NC_DB_USER=nocodb
NC_DB_PASSWORD=changeNocodbPassword
NC_DB=nocodb
NC_ALLOW_LOCAL_EXTERNAL_DBS=true

# Prod: subdomain served by Caddy
NC_HOST=back-office-coaction.byst.re

# Separate app database on the same Postgres instance, split into two roles
# (see docker/init-data.sh and .ai/IMPLEMENTATION_PLAN.md §2.2):
APP_DB=appdata

# Owner of the appdata DB — runs migrations/seeds (app_migrate.sh, app_seed.sh).
# NEVER used by NocoDB — it can create/alter tables, NocoDB must not be able to.
APPDATA_OWNER_USER=appdata_owner
APPDATA_OWNER_PASSWORD=changeAppdataOwnerPassword

# Restricted role NocoDB connects with as an external Base (host: postgres, port: 5432).
# Scoped to SELECT/INSERT/UPDATE/DELETE on schema `crm` only (views over appdata.*) —
# granted once migrations create that schema, see docker/migrations/0010_grants_nocodb_crm_user.sql.
NOCODB_CRM_USER=nocodb_crm_user
NOCODB_CRM_PASSWORD=changeNocodbCrmPassword
