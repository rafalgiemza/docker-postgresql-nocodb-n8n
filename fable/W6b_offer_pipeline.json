{
  "name": "W6b - Offer production pipeline (goals -> testimonials -> draft)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "w6b-offer-pipeline",
        "options": {}
      },
      "id": "node-061",
      "name": "NocoDB: leads updated",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "webhookId": "wh-w6b-offer-pipeline"
    },
    {
      "parameters": {
        "jsCode": "// Offer production pipeline guard: react only to real offer_prep_status changes.\nconst b = $input.first().json.body || $input.first().json;\nconst row  = (b.data && b.data.rows && b.data.rows[0]) || {};\nconst prev = (b.data && b.data.previous_rows && b.data.previous_rows[0]) || {};\nconst s = row.offer_prep_status, p = prev.offer_prep_status;\nif (!s || s === p) return [];\nif (s !== 'goals_provided' && s !== 'testimonials_provided') return [];\nconst name = row.contact_name || ('lead #' + row.Id);\nreturn [{ json: { branch: s, lead_id: row.Id, lead_name: name } }];"
      },
      "id": "node-062",
      "name": "Guard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "mode": "expression",
        "numberOutputs": 2,
        "output": "={{ ['goals_provided','testimonials_provided'].indexOf($json.branch) }}"
      },
      "id": "node-063",
      "name": "Route by status",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        400,
        0
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://back-office-coaction-test.giemza.dev/api/v2/tables/mdqdz4zjmarhmmu/records?where=(description,like,%lead:{{ $('Guard').item.json.lead_id }}%)~and(title,like,Define training goals%)~and(status,neq,done)&limit=20",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "node-064",
      "name": "Find open goals tasks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        600,
        -150
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": null,
          "name": "NocoDB Token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Close the previous pipeline task(s) for this lead (bulk PATCH payload).\nconst tasks = $input.first().json.list || [];\nreturn [{ json: { patches: tasks.map(t => ({ Id: t.Id, status: 'done' })) } }];"
      },
      "id": "node-065",
      "name": "Build close patches (goals)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        -150
