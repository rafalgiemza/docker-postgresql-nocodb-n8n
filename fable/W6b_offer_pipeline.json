      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": null,
          "name": "NocoDB Token"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// goals_provided: prepare the testimonials task + activity.\nconst src = $('Guard').item.json;\nreturn [{ json: { ...src,\n  task: { title: `Select testimonials: ${src.lead_name}`, status: 'todo',\n          priority: 'normal', assignee: 'katarzyna@coaction.pl', created_by_flow: 'W6b',\n          description: `lead:${src.lead_id}\\nPick matching testimonials/case studies and link them to the lead.` },\n  activity: { summary: `Goals saved, testimonials requested (${src.lead_name})`,\n              type: 'goals_provided', flow: 'W6b', triggered_by: 'user',\n              payload: JSON.stringify({ lead_id: src.lead_id }) }\n} }];"
      },
