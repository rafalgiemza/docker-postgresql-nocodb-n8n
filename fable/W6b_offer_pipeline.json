      "parameters": {
        "jsCode": "// testimonials_provided: verify that at least one testimonial is actually linked.\nconst src = $('Guard').item.json;\nconst linked = ($input.first().json.list || []).length;\nreturn [{ json: { ...src, linked, ok: linked > 0,\n  patch_lead: { Id: src.lead_id, offer_prep_status: 'draft_ready' },\n  task: { title: `Offer draft ready - assemble the offer: ${src.lead_name}`,\n          status: 'todo', priority: 'high', assignee: 'przemek.fidzina@coaction-test.pl',\n          created_by_flow: 'W6b', description: `lead:${src.lead_id}` },\n  comment: 'No testimonials linked. Please link at least one testimonial to the lead ' +\n           'and set offer_prep_status back to testimonials_provided.',\n  activity_ok: { summary: `${linked} testimonial(s) linked, offer draft ready (${src.lead_name})`,\n                 type: 'testimonials_provided', flow: 'W6b', triggered_by: 'user',\n                 payload: JSON.stringify({ lead_id: src.lead_id, linked }) },\n  activity_err: { summary: `testimonials_provided set but no testimonials linked (${src.lead_name})`,\n                  type: 'automation_error', flow: 'W6b', triggered_by: 'system',\n                  payload: JSON.stringify({ lead_id: src.lead_id }) }\n} }];"
      },
