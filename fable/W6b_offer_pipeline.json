    {
      "parameters": {
        "method": "PATCH",
        "url": "https://back-office-coaction-test.giemza.dev/api/v2/tables/mdqdz4zjmarhmmu/records",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.patches) }}"
      },
      "id": "node-066",
      "name": "Close goals tasks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
