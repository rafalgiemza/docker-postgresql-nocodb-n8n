    {
      "parameters": {
        "jsCode": "// Lead created - prepare first-contact task and the activity entry.\nconst leadId = $input.first().json.Id;\nconst lead = $('Map Tally fields').item.json.lead;\nreturn [{ json: {\n  lead_id: leadId,\n  task: { title: `Schedule discovery call: ${lead.contact_name}`, status: 'todo',\n          priority: 'high', assignee: 'przemek.fidzina@coaction-test.pl', created_by_flow: 'W4',\n          description: `lead:${leadId}\\nPhone: ${lead.contact_phone}\\nEmail: ${lead.contact_email}` },\n  activity: { summary: `Lead created from Tally form: ${lead.contact_name}`,\n              type: 'lead_created', flow: 'W4', triggered_by: 'system',\n              payload: JSON.stringify({ lead_id: leadId, email: lead.contact_email }) }\n} }];"
      },
