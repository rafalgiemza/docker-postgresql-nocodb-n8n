    {
      "parameters": {
        "jsCode": "// Map Tally webhook payload -> lead. EDIT LABELS to match your Tally form fields.\nconst LABELS = { name: 'Imię i nazwisko', email: 'E-mail', phone: 'Telefon', notes: 'Wiadomość' };\nconst PUBLIC = /@(gmail|googlemail|wp|o2|onet|op|interia|icloud|me|outlook|hotmail|live|proton|protonmail|yahoo|gazeta)\\./i;\nconst b = $input.first().json.body || $input.first().json;\nconst fields = (b.data && b.data.fields) || [];\nconst get = label => {\n  const f = fields.find(f => (f.label || '').trim().toLowerCase() === label.toLowerCase());\n  if (!f) return undefined;\n  return (f.value && f.value.text) || f.value;\n};\nconst emailAddr = String(get(LABELS.email) || '');\nreturn [{ json: { lead: {\n  contact_name: get(LABELS.name) || 'Unknown',\n  contact_email: emailAddr,\n  contact_phone: String(get(LABELS.phone) || ''),\n  notes: String(get(LABELS.notes) || ''),\n  source: 'formularz', contact_channel: 'formularz',\n  stage: 'new', state: 'open', qualification: 'unqualified',\n  offer_prep_status: 'none', company_match_status: 'none',\n  owner: 'przemek.fidzina@coaction-test.pl',\n  type: PUBLIC.test(emailAddr) ? 'B2C' : 'B2B'\n} } }];"
      },
      "id": "node-021",
      "name": "Map Tally fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://back-office-coaction-test.giemza.dev/api/v2/tables/mx00y54712018vc/records",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.lead) }}"
      },
      "id": "node-022",
      "name": "Create lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
