    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'anthropic/claude-sonnet-4.5', messages: [{ role: 'system', content: 'You are an assistant of an English training company (CoAction). Analyse the discovery call transcript. Extract: client goals, challenges, participant types, business context, key communication situations, and a suggested training direction (Business English / English for IT / English + Business Skills). Answer in Polish with clear headings.' },{ role: 'user', content: $('Resolve lead').item.json.transcript }] }) }}"
      },
      "id": "node-042",
      "name": "Call OpenRouter",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        -300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": null,
          "name": "OpenRouter"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse OpenRouter response, prepare meeting patch, verify-task and activity.\nconst src = $('Resolve lead').item.json;\nconst res = $input.first().json;\nconst content = res.choices && res.choices[0] && res.choices[0].message\n  && res.choices[0].message.content || '';\nif (!content) throw new Error('Empty LLM response: ' + JSON.stringify(res).slice(0, 400));\nreturn [{ json: { ...src,\n  patch: { Id: src.meeting_id, ai_analysis: content, processing_status: 'ai_draft_ready' },\n  task: { title: `Verify AI analysis: ${src.meeting_title}`, status: 'todo',\n          priority: 'high', assignee: src.owner_email, created_by_flow: 'W6a',\n          description: `meeting:${src.meeting_id}` },\n  activity: { summary: `AI analysis ready for meeting: ${src.meeting_title}`,\n              type: 'ai_analysis_done', flow: 'W6a', triggered_by: 'system',\n              payload: JSON.stringify({ meeting_id: src.meeting_id,\n                model: 'anthropic/claude-sonnet-4.5', usage: res.usage || null }) }\n} }];"
      },
      "id": "node-043",
      "name": "Parse LLM response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        -300
      ]
    },
