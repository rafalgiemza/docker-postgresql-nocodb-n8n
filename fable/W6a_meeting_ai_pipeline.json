        "jsCode": "// ai_rejected / missing_transcript: create a fix-it task + activity.\nconst src = $('Resolve lead').item.json;\nconst missing = src.branch === 'missing_transcript';\nreturn [{ json: { ...src,\n  task: { title: (missing ? 'Paste transcript: ' : 'Fix notes & rerun AI analysis: ')\n                 + src.meeting_title,\n          status: 'todo', priority: 'high', assignee: src.owner_email,\n          created_by_flow: 'W6a', description: `meeting:${src.meeting_id}` },\n  activity: { summary: (missing ? 'AI analysis skipped - transcript missing: '\n                                 : 'AI draft rejected: ') + src.meeting_title,\n              type: missing ? 'automation_error' : 'ai_analysis_done',\n              flow: 'W6a', triggered_by: missing ? 'system' : 'user',\n              payload: JSON.stringify({ meeting_id: src.meeting_id, branch: src.branch }) }\n} }];"
