        "url": "=https://back-office-coaction-test.giemza.dev/api/v2/tables/mdqdz4zjmarhmmu/records?where=(description,like,%meeting:{{ $('Resolve lead').item.json.meeting_id }}%)~and(status,neq,done)&limit=20",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
