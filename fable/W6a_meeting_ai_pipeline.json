    {
      "parameters": {
        "jsCode": "// Resolve the linked lead id via the Links API (webhook rows carry only link counts).\nconst src = $('Guard').item.json;\nconst list = $input.first().json.list || [];\nconst lead_id = list[0] && (list[0].Id || list[0].id);\nreturn [{ json: { ...src, lead_id: lead_id || null } }];"
      },
      "id": "node-040",
      "name": "Resolve lead",
      "type": "n8n-nodes-base.code",
