      "parameters": {
        "jsCode": "// Mark all open verify-tasks of this meeting as done (bulk PATCH payload).\nconst tasks = $input.first().json.list || [];\nconst patches = tasks.map(t => ({ Id: t.Id, status: 'done' }));\nreturn [{ json: { patches, has_any: patches.length > 0 } }];"
