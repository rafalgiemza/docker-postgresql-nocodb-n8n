{
  "name": "W6a - Meeting AI pipeline (transcript -> analysis -> accept)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "w6a-meeting-ai",
        "options": {}
      },
      "id": "node-037",
      "name": "NocoDB: meetings updated",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "webhookId": "wh-w6a-meeting-ai"
    },
    {
      "parameters": {
        "jsCode": "// Meeting AI pipeline guard: act only on real processing_status transitions.\nconst b = $input.first().json.body || $input.first().json;\nconst row  = (b.data && b.data.rows && b.data.rows[0]) || {};\nconst prev = (b.data && b.data.previous_rows && b.data.previous_rows[0]) || {};\nconst s = row.processing_status, p = prev.processing_status;\nif (!s || s === p) return [];\nlet branch = null;\nif (s === 'analysis_pending')\n  branch = (row.transcript && String(row.transcript).trim().length > 50)\n    ? 'analysis_pending' : 'missing_transcript';\nif (s === 'ai_accepted') branch = 'ai_accepted';\nif (s === 'ai_rejected') branch = 'ai_rejected';\nif (!branch) return [];\nconst ownerRaw = row.owner;\nconst owner = (Array.isArray(ownerRaw) ? ownerRaw[0] && ownerRaw[0].email\n              : ownerRaw && ownerRaw.email) || 'przemek.fidzina@coaction-test.pl';\nreturn [{ json: { branch, meeting_id: row.Id,\n  meeting_title: row.title || ('meeting #' + row.Id),\n  owner_email: owner, transcript: row.transcript || '' } }];"
      },
      "id": "node-038",
      "name": "Guard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://back-office-coaction-test.giemza.dev/api/v2/tables/marzjzld5cynlfw/links/coydw2dymwf0tkf/records/{{ $json.meeting_id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "node-039",
      "name": "Get linked lead",
