    {
      "parameters": {
        "jsCode": "// ai_accepted: route the goals task by lead type and prepare all payloads.\nconst src = $('Resolve lead').item.json;\nconst lead = $input.first().json;\nconst methodologist = lead.type === 'B2B' ? 'dorota@coaction.pl' : 'aleksandra@coaction.pl';\nconst name = lead.contact_name || ('lead #' + lead.Id);\nreturn [{ json: { ...src,\n  patch_lead: { Id: lead.Id, offer_prep_status: 'waiting_goals' },\n  task: { title: `Define training goals: ${name}`, status: 'todo', priority: 'normal',\n          assignee: methodologist, created_by_flow: 'W6a',\n          description: `lead:${lead.Id}\\nBased on accepted AI analysis of: ${src.meeting_title}` },\n  activity: { summary: `AI draft accepted, goals requested (${name})`,\n              type: 'ai_accepted', flow: 'W6a', triggered_by: 'user',\n              payload: JSON.stringify({ meeting_id: src.meeting_id, lead_id: lead.Id,\n                assigned_to: methodologist }) }\n} }];"
      },
