# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

N8N_VERSION=stable

# Postgres superuser (used only for init; n8n never connects with this account)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeMe
POSTGRES_DB=n8n

# Separate, least-privilege account n8n actually connects with.
# Must be DIFFERENT from POSTGRES_USER above.
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=changeMeToo

# Shared secret between n8n and the task runner. Generate with: openssl rand -hex 32
RUNNERS_AUTH_TOKEN=changeRunnerAuthToken

# Encrypts credentials stored by n8n. Generate once with: openssl rand -hex 32
# Losing this key after workflows have saved credentials makes them unrecoverable.
N8N_ENCRYPTION_KEY=changeEncryptionKey

# Public-facing hostname/protocol used to build webhook URLs.
# One docker-compose.yml for both dev and prod — these three just change value
# per environment (n8n is also always reachable on 127.0.0.1:5678, see
# fragments/n8n.yml, regardless of these):
#   Local dev: N8N_HOST=localhost, N8N_PROTOCOL=http, WEBHOOK_URL=http://localhost:5678/
#   Prod:      real domain, served via Caddy, as below
N8N_HOST=n8n.giemza.dev
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.giemza.dev/

# AI/LLM Integration — MUST BE FILLED MANUALLY (not auto-generated)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=API_KEY_PLACEHOLDER

# Used by scripts/crm-wire-init.sh (`make wire-apps`) to wire NocoDB/n8n to
# appdata/crm after a hard-reset — MUST BE FILLED MANUALLY, one-time bootstrap
# per hard-reset (docs/init-nocodb.md "Krok 0", docs/hard-reset.md).
# NocoDB: sign up as super-admin in the UI, then Account → API Tokens.
NC_API_TOKEN=API_TOKEN_PLACEHOLDER
# n8n: finish the owner setup wizard in the UI, then Settings → API → Create API Key.
N8N_API_KEY=API_KEY_PLACEHOLDER

# NocoDB — separate database + user on the same Postgres instance.
NOCODB_VERSION=latest
NC_DB_USER=nocodb
NC_DB_PASSWORD=changeNocodbPassword
NC_DB=nocodb
NC_ALLOW_LOCAL_EXTERNAL_DBS=true

# Prod: subdomain served by Caddy
NC_HOST=back-office.giemza.dev

# RAG — pusta baza na tym samym Postgresie, bez schematu/migracji (patrz
# scripts/init-data.sh). Świadomie poza schema.sql/APP_DB — brak wymogów co
# do struktury na razie, tylko miejsce pod przyszłe workflowy n8n/RAG.
RAG_DB_USER=rag_db
RAG_DB_PASSWORD=changeRagDbPassword
RAG_DB=rag_db

# Separate app database on the same Postgres instance, split into two roles
# (see scripts/init-data.sh and .ai/IMPLEMENTATION_PLAN.md §2.2):
APP_DB=appdata

# Owner of the appdata DB — runs migrations/seeds (app_migrate.sh, app_seed.sh).
# NEVER used by NocoDB — it can create/alter tables, NocoDB must not be able to.
APPDATA_OWNER_USER=appdata_owner
APPDATA_OWNER_PASSWORD=changeAppdataOwnerPassword

# Restricted role NocoDB connects with as an external Base (host: postgres, port: 5432).
# Scoped to SELECT/INSERT/UPDATE/DELETE on schema `crm` only (views over appdata.*) —
# granted once schema.sql creates that schema, see schema.sql section 14.
NOCODB_CRM_USER=nocodb_crm_user
NOCODB_CRM_PASSWORD=changeNocodbCrmPassword

# Restricted role n8n connects with directly to Postgres (host: postgres, port: 5432)
# for WF-6 ("Zatwierdź ofertę"). Separate from NOCODB_CRM_USER above so n8n and NocoDB
# stay distinguishable in logs/pg_stat_activity. Scoped to SELECT/UPDATE on
# crm.v_offer_builder only for now — granted by schema.sql section 15.
N8N_CRM_USER=n8n_crm_user
N8N_CRM_PASSWORD=changeN8nCrmPassword

# MinIO — S3-compatible object storage (PRD §1.1/§8.5). Buckets + the
# restricted nocodb user below are created automatically by the one-shot
# `minio-init` service (scripts/minio-init.sh) on every `make up`.
MINIO_VERSION=latest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeMinioRootPassword

# MINIO_HOST — prod: subdomain served by Caddy, also resolved *inside* the
# Docker network via a network alias on the caddy service (see
# fragments/caddy.yml), so NocoDB's backend and a client browser hit the
# exact same hostname/URL for presigned attachment links.
# MINIO_ENDPOINT — what NocoDB's S3 client actually connects to.
#   Local dev: MINIO_ENDPOINT=http://localhost:9000 (MinIO is also always
#     reachable on 127.0.0.1:9000/9001, see fragments/minio.yml)
#   Prod:      https://<MINIO_HOST>, routed through Caddy, as below
MINIO_HOST=minio.giemza.dev
MINIO_ENDPOINT=https://minio.giemza.dev

# Buckets (PRD §8.5): offers/templates are versioned (commercial documents,
# never silently overwritten); recordings/backups expire via lifecycle rules.
MINIO_BUCKET_ATTACHMENTS=attachments
MINIO_BUCKET_OFFERS=offers
MINIO_BUCKET_TEMPLATES=templates
MINIO_BUCKET_RECORDINGS=recordings
MINIO_BUCKET_TRANSCRIPTS=transcripts
MINIO_BUCKET_BACKUPS=backups

# Least-privilege MinIO user NocoDB connects with — scoped to the
# attachments bucket only (GetObject/PutObject/DeleteObject/ListBucket),
# never the root account. Same pattern as NOCODB_CRM_USER above for Postgres.
NOCODB_MINIO_ACCESS_KEY=nocodb
NOCODB_MINIO_SECRET_KEY=changeNocodbMinioSecretKey

# LibreChat — czat AI dla zespołu (PRD §1.1). Osobny byt: własna MongoDB,
# zero integracji z danymi CRM w Postgresie. Wystawiony przez Caddy jak
# n8n/NocoDB/MinIO powyżej.
LIBRECHAT_VERSION=latest
MONGO_VERSION=7

# Ready-to-migrate (PRD §8.7): LibreChat mówi z Mongo wyłącznie przez
# MONGO_URI. Domyślnie wskazuje na lokalny kontener `mongodb` (uruchamiany
# tylko gdy profil "local-mongo" jest aktywny w COMPOSE_PROFILES poniżej).
# Gdy klient dokupi zewnętrzny/managed Mongo: podmień MONGO_URI na jego
# connection string, ustaw COMPOSE_PROFILES= (puste) i zrób
# `make down && make up` — lokalny kontener mongodb się wtedy nie odpali,
# zero zmian w plikach compose.
COMPOSE_PROFILES=local-mongo
MONGO_URI=mongodb://mongodb:27017/LibreChat

# LIBRECHAT_HOST — subdomena serwowana przez Caddy (prod) — tylko dla
# Caddyfile, jako routing hostname. Bez znaczenia w dev (LibreChat dostępny
# bezpośrednio na 127.0.0.1:3080, patrz fragments/librechat.yml).
LIBRECHAT_HOST=chat.giemza.dev

# LIBRECHAT_URL — pełny scheme+host, którego LibreChat faktycznie używa do
# cookie-domain/CORS (DOMAIN_CLIENT/DOMAIN_SERVER) — musi się zgadzać z tym,
# co widzi przeglądarka, inaczej logowanie/sesja się wysypie.
#   Local dev: LIBRECHAT_URL=http://localhost:3080
#   Prod:      https://<LIBRECHAT_HOST>, jak niżej
LIBRECHAT_URL=https://chat.giemza.dev

# Otwarta rejestracja — każdy z linkiem do LIBRECHAT_HOST może założyć konto.
# Po tym, jak zespół już ma konta, przełącz na false w .env (make down && make up).
ALLOW_REGISTRATION=true

# Sekrety sesji/JWT i szyfrowania credentiali zapisywanych w Mongo przez
# LibreChat. JWT_SECRET/JWT_REFRESH_SECRET/CREDS_KEY generuje generate-env.sh
# (32-bajtowy hex pasuje do wszystkich trzech).
JWT_SECRET=changeLibrechatJwtSecret
JWT_REFRESH_SECRET=changeLibrechatJwtRefreshSecret
CREDS_KEY=changeLibrechatCredsKey

# CREDS_IV: wektor inicjujący AES-CBC, MUSI mieć dokładnie 16 bajtów —
# generate-env.sh generuje wyłącznie sekrety 32-bajtowe, więc ten placeholder
# celowo NIE zaczyna się od "change" (nie zostanie nadpisany automatycznie).
# Wygeneruj ręcznie: openssl rand -hex 16
CREDS_IV=CREDS_IV_PLACEHOLDER_16BYTE

# LibreChat czyta klucz endpointu custom (librechat.yaml) z env var o
# dokładnie takiej nazwie, jaka jest w yamlu. Reużywamy istniejący
# OPENROUTER_API_KEY (bez trzymania drugiego sekretu) pod nazwą OPENROUTER_KEY
# — nazwanie tego OPENROUTER_API_KEY przekierowałoby też wbudowany endpoint
# OpenAI LibreChata przez OpenRouter, czego nie chcemy. Rebind we fragmentach
# compose: OPENROUTER_KEY=${OPENROUTER_API_KEY}.

# Uptime Kuma — monitoring/alerting (post-mortem/tasks.md Task 1). STATUS_HOST
# to subdomena serwowana przez Caddy (prod) — jak LIBRECHAT_HOST, bez
# znaczenia w dev, gdzie Kuma jest dostępny bezpośrednio na 127.0.0.1:3001
# (patrz fragments/uptime-kuma.yml). Monitory i kanały alertów konfiguruje
# się ręcznie w Kuma po pierwszym uruchomieniu
# — nie wymaga sekretów w .env.
STATUS_HOST=status.giemza.dev
