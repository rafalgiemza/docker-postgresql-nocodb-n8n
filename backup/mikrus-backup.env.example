# Copy to /etc/mikrus-backup.env on the VPS (chmod 600, root-only) — kept
# OUTSIDE this repo, never committed. Sourced before backup/backup.sh runs
# (see the cron examples at the bottom of that script).

RESTIC_REPOSITORY=rclone:offsite:coaction-backups
RESTIC_PASSWORD=CHANGE_ME_SET_ON_THE_VPS_NOT_IN_GIT
